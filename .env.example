# Copy to .env.local — never commit secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Intake webhook (POST /api/webhooks/intake with header x-webhook-secret)
INTAKE_WEBHOOK_SECRET=

# Job runner: Vercel Cron or manual curl — must match CRON_SECRET
CRON_SECRET=

# Resend (persona outbound)
RESEND_API_KEY=
EMAIL_FROM="Sarah Chen <partnerships@yourdomain.com>"

# Stripe (Invoicing + webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Documenso hosted API
DOCUMENSO_API_URL=https://app.documenso.com
DOCUMENSO_API_KEY=

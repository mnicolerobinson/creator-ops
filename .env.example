# Copy to .env.local — never commit secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://app.creatrops.com
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Intake webhook (POST /api/webhooks/intake with header x-webhook-secret)
INTAKE_WEBHOOK_SECRET=

# Job runner: Vercel Cron or manual curl — must match CRON_SECRET
CRON_SECRET=

# Resend (persona outbound)
RESEND_API_KEY=
EMAIL_FROM="CreatrOps <noreply@clairenhaus.com>"

# Stripe (Invoicing + webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=
STRIPE_PRICE_STARTER_OPS=
STRIPE_PRICE_GROWTH_OPS=
STRIPE_PRICE_CREATOR_CEO=

# Documenso hosted API
DOCUMENSO_API_URL=https://app.documenso.com
DOCUMENSO_API_KEY=

# App
OPS_EMAIL_DOMAIN=ops.creatrops.com
